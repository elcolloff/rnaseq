nextflow_pipeline {

    name "Test pipeline with integer sample names"
    script "../main.nf"
    tag "pipeline"

    test("Params: integer sample names") {

        when {
            params {
                outdir = "$outputDir"
                input  = "$projectDir/tests/csv/samplesheet_integer_samples.csv"
            }
        }

        then {
            def stable_path = getAllFilesFromDir(params.outdir, relative: true, includeDir: true, ignore: ['pipeline_info/*.{html,json,txt}'])
            def stable_content = getAllFilesFromDir(params.outdir, ignoreFile: 'tests/.nftignore')
            assert workflow.success
            assertAll(
                { assert snapshot(
                    workflow.trace.succeeded().size(),
                    removeFromYamlMap("$outputDir/pipeline_info/nf_core_rnaseq_software_mqc_versions.yml", "Workflow"),
                    stable_path,
                    stable_content
                ).match() }
            )
        }

        cleanup {
            if (System.getenv("CI") == "true") {
                if (System.getenv("NFT_PROFILE")?.contains("docker")) {
                    "docker system prune -a -f --volumes".execute()
                }
                new File("${launchDir}").deleteDir()
            }
        }
    }

