    test("Params: integer sample names - pseudo only stub") {

        options "-stub"

        when {
            params {
                outdir           = "$outputDir"
                input            = "$projectDir/tests/csv/samplesheet_integer_samples.csv"
                skip_alignment   = true
                skip_qc          = true
                pseudo_aligner   = "kallisto"
                // Test profile's transcriptome was built with spike-ins; null these so
                // the pipeline regenerates a clean kallisto index from genome + GTF.
                additional_fasta = null
                transcript_fasta = null
            }
        }

        then {
            def stable_path = getAllFilesFromDir(params.outdir, relative: true, includeDir: true, ignore: ['pipeline_info/*.{html,json,txt}'])
